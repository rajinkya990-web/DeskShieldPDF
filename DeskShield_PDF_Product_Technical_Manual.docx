    section_title(doc, "17", "Hackathon positioning", "How to present the project credibly")
    doc.add_heading("Category and story", level=2)
    add_body(doc, "DeskShield fits Work & Productivity because it changes how employees review and present sensitive documents using ordinary equipment. The strongest story is the post-access privacy gap: authorization controls who may open the file, while DeskShield reduces what remains continuously visible after opening.")
    doc.add_heading("Innovation statement", level=2)
    add_body(doc, "The novelty is the combination of three complementary controls inside a usable local PDF workflow: spatial-frequency privacy for distance reduction, interaction-driven dynamic region disclosure, and temporal rolling-shutter disruption designed for ordinary 60 Hz office displays.")
    doc.add_heading("What to demonstrate in under three minutes", level=2)
    add_numbers(doc, [
        "Show the unprotected synthetic PDF and state the shoulder-surfing, phone-camera and screen-sharing problem.",
        "Open a local PDF and demonstrate page navigation and zoom without upload.",
        "Tune Clarity at the seated position.",
        "Move Rectangle, Full row and Spotlight between non-contiguous regions in a mock call.",
        "Compare Unprotected with Rolling bands using a named phone and fixed distance; show a failure case if one occurs.",
        "Show the source, matching PDF.js worker, extension package and test command.",
        "Explain Codex/GPT-5.6 contribution accurately; do not describe deterministic runtime graphics as AI.",
    ])
    doc.add_heading("Submission readiness", level=2)
    add_table(doc, ["Item", "Status"], [
        ["Compilable web source", "Complete"],
        ["Manifest V3 extension source and ZIP", "Complete"],
        ["Synthetic sample PDF", "Complete"],
