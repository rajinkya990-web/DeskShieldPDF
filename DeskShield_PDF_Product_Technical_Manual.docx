        ["Repository/license or private judge sharing", "Pending"],
        ["Accurate Codex/GPT-5.6 contribution description", "Complete"],
        ["Codex /feedback Session ID", "Complete"],
    ], [5700, 3660])
    add_callout(doc, "Codex /feedback Session ID", CODEX_SESSION_ID, "teal")
    add_callout(doc, "Judging credibility", "A measured, honest claim is stronger than “camera-proof.” Show both the intended effect and the boundary where a close, zoomed or computational camera recovers content.", "teal")

    section_title(doc, "18", "Roadmap", "Improvements that increase usability, evidence and defensibility")
    add_table(doc, ["Priority", "Feature", "Outcome"], [
        ["P0", "Execute multi-phone, multi-monitor camera matrix", "Converts an interesting mechanism into reproducible evidence"],
        ["P0", "Add saved profiles by monitor and task", "One-click “desk,” “meeting,” and “camera test” configurations"],
        ["P1", "Calibration wizard using test strings and comfort scoring", "Guides users to the lowest usable Clarity setting"],
        ["P1", "Meeting safe-state and share preview", "Defaults to obscured output until the presenter deliberately reveals a region"],
