        ["P2", "Cross-platform packaging and managed enterprise deployment", "Moves from developer-mode test build toward operational adoption"],
    ], [900, 3770, 4690], 8.4)
    add_callout(doc, "Safety requirement", "Any faster or higher-contrast animation must be reviewed for flicker comfort, photosensitive seizure risk, accessibility and enterprise policy before production use.", "risk")

    section_title(doc, "19", "Reference appendices", "Quick facts, project structure and responsible-use checklist")
    doc.add_heading("A. Quick facts", level=2)
    add_table(doc, ["Property", "Current value"], [
        ["Product version", "0.1.0"],
        ["Primary runtime", "React + PDF.js + layered HTML canvas"],
        ["Web framework/build", "Next-compatible React application built with Vinext/Vite"],
        ["Extension", "Chrome/Edge Manifest V3, dedicated viewer tab"],
        ["PDF.js", "6.1.200 with matching local worker"],
        ["Privacy modes", "Clarity, Mouse window, Rolling bands"],
        ["Window shapes", "Oval band, Rectangle, Full row, Spotlight"],
        ["Rolling rates", "60, 30, 20 fps"],
        ["Zoom", "60–180% in 10% steps"],
        ["Network use for selected PDF", "None intentionally; local file bytes are passed to PDF.js"],
    ], [3100, 6260])
    doc.add_heading("B. Project structure", level=2)
    add_table(doc, ["Path", "Contents"], [
        ["app/", "Web viewer UI, state and overlay implementation"],
        ["extension-src/", "Manifest V3 extension source"],
        ["public/", "Synthetic PDF and local PDF.js assets"],
        ["scripts/", "Reproducible extension build script"],
        ["release/", "Unpacked extension and downloadable ZIP"],
        ["tests/", "Automated validation"],
        ["docs/", "Camera protocol, screenshots and this manual"],
        ["README.md / SUBMISSION.md", "Build guidance, claims, demo script and submission checklist"],
    ], [3200, 6160])
    doc.add_heading("C. Responsible-use checklist", level=2)
    add_bullets(doc, [
        "Use synthetic or authorized documents for demonstrations and camera testing.",
        "State the exact hardware, distance and settings behind every result.",
        "Retain the Unprotected baseline and all repeated captures.",
        "Do not label content “camera-proof” or imply protection against screenshots or compromised endpoints.",
        "Stop sharing before disabling Privacy and lock the workstation when unattended.",
        "Review animation comfort and accessibility before enterprise deployment.",
    ])
    add_callout(doc, "Final summary", "DeskShield is already useful as a selective-disclosure PDF viewer and as a disciplined experiment in camera-resistant presentation. Its path from prototype to product depends on measurement, safe defaults, managed deployment and precise claims.", "teal")

    doc.save(OUTPUT)
    print(OUTPUT)


if __name__ == "__main__":
    build_manual()
