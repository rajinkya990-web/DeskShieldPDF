    section_title(doc, "16", "Quality assurance and troubleshooting", "Automated evidence, manual checks and common failures")
    doc.add_heading("Automated coverage", level=2)
    add_body(doc, "The project includes build-output and extension validation. Existing checks verify that the web project compiles, the extension is Manifest V3, the package includes PDF.js and a version-matched worker, local PDF bytes are accepted, all three privacy methods exist, and no network URL is embedded in the extension runtime.")
    add_callout(doc, "Scope of automation", "Passing automated checks proves packaging and source invariants. It does not prove camera resistance, human comfort, meeting-platform compatibility or accessibility on every device.", "neutral")
    doc.add_heading("Troubleshooting", level=2)
    add_table(doc, ["Symptom", "Likely cause", "Action"], [
        ["PDF does not render", "PDF.js module/worker mismatch or invalid source", "Rebuild so module and worker come from the same installed package; confirm a local data parameter reaches getDocument"],
        ["Extension shows files but cannot install", "ZIP opened as a folder instead of loading unpacked source", "Extract the ZIP, then select the extracted folder in the extensions page"],
        ["Toolbar overflows", "Browser viewport is extremely narrow or zoomed", "Reset browser zoom, widen the window or use fullscreen; core responsive styles hide secondary controls first"],
        ["Mouse window seems missing", "Pointer is outside the document or Privacy/method is not active", "Enable Privacy, select Mouse window and move the pointer over the PDF canvas"],
        ["Clarity slider appears ineffective", "Value near 100% intentionally approaches the clear page", "Reduce the value substantially and compare against Privacy off"],
        ["Rolling bands are readable in a photo", "Timing, exposure, HDR fusion or zoom bypassed the effect", "Test 60/30/20 fps, repeat captures, disable computational modes where possible and record the failure"],
    ], [2100, 3050, 4210], 8.3)
